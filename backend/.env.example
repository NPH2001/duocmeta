# Backend runtime
APP_NAME=duocmeta-backend
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
TRUSTED_HOSTS=localhost,127.0.0.1,testserver,backend

# Security
SECRET_KEY=change-me
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30
SECURITY_CONTENT_SECURITY_POLICY="default-src 'none'; frame-ancestors 'none'; base-uri 'none'; form-action 'none'"
SECURITY_PERMISSIONS_POLICY="camera=(), microphone=(), geolocation=(), payment=()"
SECURITY_REFERRER_POLICY=strict-origin-when-cross-origin
SECURITY_HSTS_ENABLED=false
SECURITY_HSTS_MAX_AGE_SECONDS=31536000

# Data stores
DATABASE_URL=postgresql+psycopg://duocmeta:change-me@postgres:5432/duocmeta
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Storage
S3_ENDPOINT_URL=http://minio:9000
S3_BUCKET_NAME=duocmeta-media
S3_ACCESS_KEY_ID=change-me
S3_SECRET_ACCESS_KEY=change-me
S3_REGION=us-east-1

# Error tracking (provider-neutral logging sink by default)
ERROR_TRACKING_ENABLED=true
ERROR_TRACKING_PROVIDER=logging

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_USE_REDIS=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_AUTH_LIMIT=10
RATE_LIMIT_CART_LIMIT=60
RATE_LIMIT_CHECKOUT_LIMIT=20
RATE_LIMIT_KEY_PREFIX=duocmeta:rate_limit
